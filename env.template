# ==========================================
# EXEMPLE de variables d'environnement
# ==========================================
#
# ⚠️  IMPORTANT :
# 1. Copiez ce fichier vers .env.local :  cp env.template .env.local
# 2. Renseignez vos vraies valeurs dans .env.local
# 3. Ne jamais committer .env.local (déjà dans .gitignore)
#

# ------------------------------------------
# 🖥️  DÉVELOPPEMENT LOCAL (MySQL local)
# ------------------------------------------
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=onlinereports
DB_PORT=3306

# Forcer l'utilisation de la base locale (même si NODE_ENV=production)
USE_LOCAL_DB=true

# ------------------------------------------
# 🔐 NextAuth (OBLIGATOIRE)
# ------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=votre-secret-tres-long-minimum-32-caracteres-aleatoire

# ------------------------------------------
# 🔑 Google OAuth (optionnel - désactivez si pas besoin)
# ------------------------------------------
GOOGLE_CLIENT_ID=votre-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-votre-client-secret

# ------------------------------------------
# 📧 Email / Nodemailer (pour OTP et notifications)
# ------------------------------------------
EMAIL_USER=votre-email@gmail.com
EMAIL_PASSWORD=votre-mot-de-passe-application

# Alias optionnels (certains fichiers utilisent ces noms)
# GMAIL_USER=votre-email@gmail.com
# GMAIL_APP_PASSWORD=votre-mot-de-passe-application

# ------------------------------------------
# 🌐 PRODUCTION UNIQUEMENT (Aiven MySQL)
# ------------------------------------------
# Décommentez et remplissez en production
# USE_LOCAL_DB=false
# NODE_ENV=production
# AIVEN_HOST=votre-host-aiven.aivencloud.com
# AIVEN_PORT=21094
# AIVEN_USER=votre-username-aiven
# AIVEN_PASSWORD=votre-password-aiven
# AIVEN_DATABASE=votre-nom-database
# NEXTAUTH_URL=https://votre-site.netlify.app